// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  emailVerified          DateTime?
  createdAt              DateTime  @default(now())
  freeQuestionsUsed      Int      @default(0)
  paidQuestionsRemaining Int      @default(0)

  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]
  purchases     Purchase[]
}

// Tabele wymagane przez Auth.js (adapter Prisma)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]
  scrapedSources ScrapedSource[]
}

enum MessageRole {
  user
  assistant
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  modelUsed      String?
  inputTokens    Int?
  outputTokens   Int?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

enum ScrapedSourceKind {
  organization
  grant
}

enum ScrapedSourceStatus {
  pending
  done
  error
}

model ScrapedSource {
  id             String              @id @default(cuid())
  conversationId String
  kind           ScrapedSourceKind
  rootUrl        String
  status         ScrapedSourceStatus @default(pending)
  summary        String?
  createdAt      DateTime            @default(now())

  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  pages        ScrapedPage[]
}

enum ScrapedPageContentType {
  html
  pdf
}

model ScrapedPage {
  id          String                 @id @default(cuid())
  sourceId    String
  url         String
  contentType ScrapedPageContentType
  title       String
  textContent String
  createdAt   DateTime               @default(now())

  source ScrapedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

enum PurchaseStatus {
  pending
  paid
  failed
}

model Purchase {
  id               String         @id @default(cuid())
  userId           String
  stripeSessionId  String?        @unique
  packageName      String
  questionsGranted Int
  amountPln        Int
  status           PurchaseStatus @default(pending)
  createdAt        DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model FreeQuota {
  id        String   @id            // "device:<uuid>" lub "ip:<hash>:<RRRR-MM-DD>"
  used      Int      @default(0)
  updatedAt DateTime @updatedAt
}
