# Skopiuj ten plik do .env.local i uzupełnij prawdziwymi wartościami.
# .env.local NIGDY nie trafia do gita (patrz .gitignore).

# Baza danych — connection string z neon.tech (PostgreSQL, także lokalnie)
DATABASE_URL=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js — losowy sekret, np. wynik `openssl rand -base64 32`
AUTH_SECRET=""

# Resend — wysyłka maili z linkiem logującym (etap 2)
RESEND_API_KEY=""
EMAIL_FROM="Asystent Grantowy <onboarding@resend.dev>"

# Adresy e-mail z dostępem do panelu admina (oddzielone przecinkami)
ADMIN_EMAILS="twoj@email.pl"

# Anthropic — klucz API do rozmów z AI (etap 3)
ANTHROPIC_API_KEY=""

# Stripe — klucze testowe (etap 5)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
